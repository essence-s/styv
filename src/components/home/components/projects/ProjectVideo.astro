---
interface Props {
  imageSrc: string;
  videoSrc?: string;
  title: string;
}

const { imageSrc, videoSrc, title } = Astro.props;
---

<div class='project-video' data-video-src={videoSrc}>
  <img class='project-video__image' src={imageSrc} alt={title} />
  {
    videoSrc && (
      <button class='project-video__play-btn' aria-label='Reproducir video'>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          width='24'
          height='24'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          class='lucide lucide-play-icon lucide-play'
        >
          <path d='M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z' />
        </svg>
      </button>
    )
  }
</div>

<script>
  document.addEventListener('astro:page-load', initVideos);
  document.addEventListener('astro:after-swap', initVideos);

  function initVideos() {
    const videoContainers = document.querySelectorAll('.project-video');

    videoContainers.forEach((container) => {
      const playBtn = container.querySelector('.project-video__play-btn');

      playBtn?.addEventListener('click', () => {
        const wrapper = container as HTMLElement;
        const videoSrc = wrapper.dataset.videoSrc;

        if (videoSrc) {
          wrapper.classList.add('project-video-has-video');
          wrapper.innerHTML = `
            <iframe
              src="${videoSrc}?autoplay=1"
              title="Video"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="width: 100%;height: 100%;"
            ></iframe>
          `;
        }
      });
    });
  }
</script>

<style>
  .project-video {
    position: relative;
    width: 100%;
    height: 400px;
    /* padding-bottom: 56.25%; */
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    cursor: pointer;
  }

  .project-video__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-video__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background 0.2s ease;
    color: #28292d;
  }

  .project-video__play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background: #fff;
  }
</style>
